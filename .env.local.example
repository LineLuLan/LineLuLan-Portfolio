# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets in this file.

# Web3Forms access key — get free at https://web3forms.com
# Exposed to the browser (NEXT_PUBLIC_*) because Web3Forms free plan only allows
# client-side calls. The key is intended to be public per Web3Forms docs.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Email destination (display only; Web3Forms routes to whatever email you registered)
CONTACT_EMAIL=tnanh.gdsciu@gmail.com

# Public site URL (used for OG images, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://linelulan.dev
